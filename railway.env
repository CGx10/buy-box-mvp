# Railway Environment Variables
NODE_ENV=production
PORT=3000

# AI Engine Configuration
DEFAULT_AI_ENGINE=gemini
ENABLE_TRADITIONAL=true
ENABLE_OPENAI=false
ENABLE_CLAUDE=false
ENABLE_GEMINI=true
ENABLE_OLLAMA=false
ENABLE_HYBRID=false

# API Keys (you'll need to set these in Railway dashboard)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Security
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# CORS
CORS_ORIGIN=https://buybox-generator.web.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ANALYSIS_WINDOW_MS=60000
RATE_LIMIT_ANALYSIS_MAX_REQUESTS=5

# Logging
LOG_LEVEL=info


